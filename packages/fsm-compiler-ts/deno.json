{
  "name": "@fsm/compiler",
  "version": "0.1.0",
  "exports": {
    ".": "./src/index.ts"
  },
  "tasks": {
    "dev": "deno run --allow-all --watch src/cli/index.ts",
    "cli": "deno run --allow-all src/cli/index.ts",
    "test": "deno test --allow-all test/",
    "test:watch": "deno test --allow-all --watch test/",
    "build:npm": "deno run --allow-all --allow-read --allow-write --allow-env --allow-run scripts/build_npm.ts"
  },
  "imports": {
    "@deno/dnt": "jsr:@deno/dnt@^0.41.3",
    "@std/assert": "jsr:@std/assert@1",
    "@std/cli": "jsr:@std/cli@1",
    "@types/pg": "npm:@types/pg@^8.18.0",
    "ajv": "npm:ajv@^8.18.0",
    "dotenv": "npm:dotenv@^16.5.0",
    "pg": "npm:pg@^8.20.0",
    "type-fest": "npm:type-fest@^4.41.0",
    "uuid": "npm:uuid@^11.1.0",
    "xstate": "npm:xstate@^5.19.4"
  }
}
