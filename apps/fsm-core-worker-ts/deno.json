{
  "name": "@pgfsm/worker",
  "version": "0.1.0",
  "license": "MIT",
  "exports": {
    ".": "./src/index.ts"
  },
  "imports": {
    "@std/cli": "jsr:@std/cli@1",
    "@types/pg": "npm:@types/pg@^8.15.2",
    "dotenv": "npm:dotenv@^16.5.0",
    "pg": "npm:pg@^8.16.0",
    "xstate": "npm:xstate@^5.26.0"
  },
  "tasks": {
    "dev": "deno run --allow-all --watch src/cli/index.ts",
