    "@supabase/supabase-js": "npm:@supabase/supabase-js@^2.49.8",
    "@types/pg": "npm:@types/pg@^8.15.2",
    "dotenv": "npm:dotenv@^16.5.0",
    "drizzle-kit": "npm:drizzle-kit@^0.31.9",
    "drizzle-orm": "npm:drizzle-orm@^0.45.1",
    "drizzle-zod": "npm:drizzle-zod@^0.8.3",
    "hono": "npm:hono",
    "@logtape/hono": "jsr:@logtape/hono@^2.2",
    "@logtape/logtape": "jsr:@logtape/logtape@^2.2",
    "@logtape/otel": "jsr:@logtape/otel@^2.2",
